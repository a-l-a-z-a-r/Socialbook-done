{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socialbook.local/schemas/events/review-commented.schema.json",
  "title": "ReviewCommentedEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["reviewId", "commentId", "user", "message", "targetUser"],
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "commentId": {
      "type": "string",
      "minLength": 1
    },
    "parentCommentId": {
      "type": "string",
      "minLength": 1
    },
    "user": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "targetUser": {
      "type": "string",
      "minLength": 1
    }
  }
}
